<div class=" mx-auto bg-slate-50 px-6 py-4">
  <main class="max-w-6xl">
    <header class="mb-8">
      <p class="text-sm font-medium text-slate-500">Fund Manager Workspace</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">
        LP Pipeline
      </h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Track prospective limited partners, commitment amounts, and next fundraising actions.
      </p>
      <div class="my-6">
        <%= link_to "Add Investor",
            new_investor_path,
            class: "rounded-lg bg-slate-900 px-4 py-2 text-white" %>
      </div>
    </header>
    <section class="mb-8 grid gap-4 md:grid-cols-4">
      <% @stats.each do |stat| %>
        <%= render "shared/stat_card",
        title: stat[:title],
        value: stat[:value],
        description: stat[:description] %>
      <% end %>
    </section>
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="font-semibold text-slate-950">Investors</h2>
      </div>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-6 py-3 font-medium">Investor</th>
            <th class="px-6 py-3 font-medium">Status</th>
            <th class="px-6 py-3 text-right font-medium">Commitment</th>
            <th class="px-6 py-3 font-medium">Next Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <%= render @investors %>
        </tbody>
      </table>
    </section>
  </main>
</div>
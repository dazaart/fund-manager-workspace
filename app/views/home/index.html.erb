<div class=" mx-auto bg-slate-50 px-6 py-4">
  <main class="max-w-6xl">
    <header class="mb-8">
      <p class="text-sm font-medium text-slate-500">Fund Manager Workspace</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">
        LP Pipeline
      </h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Track prospective limited partners, commitment amounts, and next fundraising actions.
      </p>
      <div class="my-6">
        <%= link_to "Add Investor",
            new_investor_path,
            class: "rounded-lg bg-slate-900 px-4 py-2 text-white" %>
      </div>
    </header>
    <section class="mb-8 grid gap-4 md:grid-cols-4">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">
          Investors
        </p>
        <p class="mt-2 text-3xl font-bold text-slate-950">
          <%= @investor_count %>
        </p>
        <p class="mt-1 text-sm text-slate-500">
          Active LP conversations
        </p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">
          Committed LPs
        </p>
        <p class="mt-2 text-3xl font-bold text-slate-950">
          <%= @committed_count %>
        </p>
        <p class="mt-1 text-sm text-slate-500">
          Ready for closing workflow
        </p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">
          Potential Capital
        </p>
        <p class="mt-2 text-3xl font-bold text-slate-950">
          <%= number_to_currency(@potential_capital, precision: 0) %>
        </p>
        <p class="mt-1 text-sm text-slate-500">
          Potential capital under discussion
        </p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <p class="text-sm font-medium text-slate-500">
          Commited Capital
        </p>
        <p class="mt-2 text-3xl font-bold text-slate-950">
          <%= number_to_currency(@total_raised, precision: 0) %>
        </p>
        <p class="mt-1 text-sm text-slate-500">
          Across all investor commitments
        </p>
      </div>
    </section>
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="font-semibold text-slate-950">Investors</h2>
      </div>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-6 py-3 font-medium">Investor</th>
            <th class="px-6 py-3 font-medium">Status</th>
            <th class="px-6 py-3 text-right font-medium">Commitment</th>
            <th class="px-6 py-3 font-medium">Next Action</th>
            <th class="px-6 py-3 font-medium">Edit</th>
            <th class="px-6 py-3 font-medium">Delete</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @investors.each do |investor| %>
            <tr class="hover:bg-slate-50 <%= investor.id == params[:highlighted_investor_id].to_i ?
  'bg-green-50' :
  '' %>">
              <td class="px-6 py-4">
                <div class="font-medium text-slate-950">
                  <%= investor.name %>
                </div>
              </td>
              <td class="px-6 py-4">
                <span
    class="rounded-full px-3 py-1 text-xs font-medium <%= status_badge_classes(investor.status) %>"<>
                  <%= investor.status %> </span>
              </td>
            </td>
            <td class="px-6 py-4 text-right font-medium text-slate-950">
              <%= number_to_currency(investor.commitment_amount, precision: 0) %>
            </td>
            <td class="px-6 py-4 text-slate-600">
              <%= investor.next_action %>
            </td>
            <td class="px-6 py-4">
              <%= link_to "Edit",
      edit_investor_path(investor),
      class: "text-blue-600 hover:underline" %>
            </td>
            <td  class="px-6 py-4">
              <%= button_to "Delete",
    investor_path(investor),
    method: :delete,
    class: "text-red-600 hover:underline",
    form: {
      data: {
        turbo_confirm: "Delete this investor?"
      }
    } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</main>
</div>
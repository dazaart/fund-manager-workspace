<div class="min-h-screen bg-slate-50 px-6 py-8">
  <div class="my-4">
    <%= link_to "Add Investor",
            investors_new_path,
            class: "rounded-lg bg-slate-900 px-4 py-2 text-white" %>
  </div>
  <main class="mx-auto max-w-6xl">
    <header class="mb-8">
      <p class="text-sm font-medium text-slate-500">Fund Manager Workspace</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-slate-950">
        LP Pipeline
      </h1>
      <p class="mt-2 max-w-2xl text-sm text-slate-600">
        Track prospective limited partners, commitment amounts, and next fundraising actions.
      </p>
    </header>
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-6 py-4">
        <h2 class="font-semibold text-slate-950">Investors</h2>
      </div>
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-6 py-3 font-medium">Investor</th>
            <th class="px-6 py-3 font-medium">Status</th>
            <th class="px-6 py-3 text-right font-medium">Commitment</th>
            <th class="px-6 py-3 font-medium">Next Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @investors.each do |investor| %>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4">
                <div class="font-medium text-slate-950">
                  <%= investor.name %>
                </div>
              </td>
              <td class="px-6 py-4">
                <% badge_classes =
    case investor.status
    when "Interested"
      "bg-yellow-100 text-yellow-800"
    when "Meeting Scheduled"
      "bg-blue-100 text-blue-800"
    when "Committed"
      "bg-green-100 text-green-800"
    else
      "bg-slate-100 text-slate-700"
    end
  %>
                <span class="rounded-full px-3 py-1 text-xs font-medium <%= badge_classes %>">
                  <%= investor.status %>
                </span>
              </td>
            </td>
            <td class="px-6 py-4 text-right font-medium text-slate-950">
              <%= number_to_currency(investor.commitment_amount, precision: 0) %>
            </td>
            <td class="px-6 py-4 text-slate-600">
              <%= investor.next_action %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </section>
</main>
</div>
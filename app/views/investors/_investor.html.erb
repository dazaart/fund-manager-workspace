<tr class="hover:bg-slate-50 <%= investor.id == params[:highlighted_investor_id].to_i ?
  'bg-green-50' :
  '' %>">
  <td class="px-6 py-4">
    <div class="font-medium text-slate-950">
      <%= investor.name %>
    </div>
  </td>
  <td class="px-6 py-4">
    <span
    class="rounded-full px-3 py-1 text-xs font-medium <%= status_badge_classes(investor.status) %>"<>
      <%= investor.status %> </span>
  </td>
</td>
<td class="px-6 py-4 text-right font-medium text-slate-950">
  <%= number_to_currency(investor.commitment_amount, precision: 0) %>
</td>
<td class="px-6 py-4 text-slate-600">
  <%= investor.next_action %>
</td>
<td class="px-6 py-4">
  <%= link_to "Edit",
      edit_investor_path(investor),
      class: "text-blue-600 hover:underline" %>
</td>
<td  class="px-6 py-4">
  <%= button_to "Delete",
    investor_path(investor),
    method: :delete,
    class: "text-red-600 hover:underline",
    form: {
      data: {
        turbo_confirm: "Delete this investor?"
      }
    } %>
</td>
</tr>
<div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <p class="mb-6 text-sm font-medium text-slate-500">
    Action timeline
  </p>
  <div class="space-y-5">
    <% Investor::ACTION_STEPS.each_with_index do |action, index| %>
      <% completed = action_completed?(investor, action) %>
      <% current = current_action?(investor, action) %>
      <div class="relative pl-8">
        <div class="absolute left-0 top-1.5 flex h-4 w-4 items-center justify-center rounded-full text-[10px] font-bold
          <%= if current
                'bg-blue-100 text-blue-800 ring-4 ring-blue-50'
              elsif completed
                'bg-slate-900 text-white'
              else
                'bg-slate-200 text-slate-500'
              end %>">
          <%= completed ? "✓" : index + 1 %>
        </div>
        <% unless index == Investor::ACTION_STEPS.length - 1 %>
          <div class="absolute left-2 top-6 h-full w-px
            <%= index < Investor::ACTION_STEPS.index(investor.next_action).to_i ? 'bg-slate-900' : 'bg-slate-200' %>">
          </div>
        <% end %>
        <p class="font-medium
  <%= if current
        'text-blue-800'
      elsif completed
        'text-slate-950'
      else
        'text-slate-400'
      end %>">
          <%= action %>
        </p>
      </p>
    </div>
  <% end %>
</div>
</div>